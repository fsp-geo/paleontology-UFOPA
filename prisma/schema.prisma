generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id
  email         String      @unique
  name          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  drillHoles    DrillHole[]
}

model Rig {
  id           String      @id @default(cuid())
  name         String      @unique
  type         String?     // RC, Diamantada, etc.
  status       String      // ATIVA, MANUTENCAO, PARADA
  contractor   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  drillHoles   DrillHole[]
}

model DrillHole {
  id             String    @id @default(cuid())
  holeId         String    @unique
  project        String
  area           String?
  status         String    // PLANEJADO, EM_ANDAMENTO, PAUSADO, CONCLUIDO, SUSPENSO
  method         String?   // RC, DDH, etc.
  targetDepth    Float
  currentDepth   Float     @default(0)
  azimuth        Float?
  dip            Float?
  startedAt      DateTime?
  finishedAt     DateTime?
  rigId          String?
  rig            Rig?      @relation(fields: [rigId], references: [id])
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DashboardMetric {
  id        String   @id @default(cuid())
  label     String
  value     String
  change    String?
  type      String   // e.g., "PRODUCTION", "DRILLING", "AVAILABILITY"
  updatedAt DateTime @updatedAt
}
