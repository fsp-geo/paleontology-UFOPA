generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String      @id
  email          String      @unique
  name           String?
  status         String      @default("active")
  userType       String      @default("internal")
  institution    String?
  department     String?
  lattesUrl      String?
  scholarUrl     String?
  researchgateUrl String?
  sigaaLogin     String?
  invitedById    String?
  invitedBy      User?       @relation("UserInvites", fields: [invitedById], references: [id])
  invitedUsers   User[]      @relation("UserInvites")
  lastLoginAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  drillHoles     DrillHole[]
  userRoles      UserRole[]  @relation("ProfileRoles")
  assignedRoles  UserRole[]  @relation("AssignedRoles")
}

model Role {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userRoles   UserRole[]
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedById String?
  assignedBy User?    @relation("AssignedRoles", fields: [assignedById], references: [id])
  user       User     @relation("ProfileRoles", fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Rig {
  id           String      @id @default(cuid())
  name         String      @unique
  type         String?     // RC, Diamantada, etc.
  status       String      // ATIVA, MANUTENCAO, PARADA
  contractor   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  drillHoles   DrillHole[]
}

model DrillHole {
  id             String    @id @default(cuid())
  holeId         String    @unique
  project        String
  area           String?
  status         String    // PLANEJADO, EM_ANDAMENTO, PAUSADO, CONCLUIDO, SUSPENSO
  method         String?   // RC, DDH, etc.
  targetDepth    Float
  currentDepth   Float     @default(0)
  azimuth        Float?
  dip            Float?
  startedAt      DateTime?
  finishedAt     DateTime?
  rigId          String?
  rig            Rig?      @relation(fields: [rigId], references: [id])
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DashboardMetric {
  id        String   @id @default(cuid())
  label     String
  value     String
  change    String?
  type      String   // e.g., "PRODUCTION", "DRILLING", "AVAILABILITY"
  updatedAt DateTime @updatedAt
}
